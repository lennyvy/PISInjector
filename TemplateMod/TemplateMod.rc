// =============================================================================
// TemplateMod.rc – Windows Resource-File
// =============================================================================
// Embeds a VERSIONINFO-Resource into your DLL. This will:
//   1. Get read by the PISInjector automaticlly (Name, Version, Author, Description)
//   2. Viewable in Windows under (RIGHTCLICK) > Properties > view details
//
// The Values come from resource.h – change them there.
//
// SETUP in Visual Studio:
//   The .rc File gets read automaticlly if it is in the project.
//   IF NOT: Project > Add > Existing Element > TemplateMod.rc
// =============================================================================

#include <winver.h>
#include "resource.h"

// =============================================================================
// VERSIONINFO – Standart Windows-Versionsinformation
// =============================================================================
// The Number-Version (z.B. 1.0.0.0) gets used for comparisons.
// The String-Version (z.B. "1.0.0") is for displaying.
// =============================================================================

VS_VERSION_INFO VERSIONINFO
    FILEVERSION     MOD_VERSION_MAJOR, MOD_VERSION_MINOR, MOD_VERSION_PATCH, MOD_VERSION_BUILD
    PRODUCTVERSION  MOD_VERSION_MAJOR, MOD_VERSION_MINOR, MOD_VERSION_PATCH, MOD_VERSION_BUILD
    FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
    FILEFLAGS       0
    FILEOS          VOS_NT_WINDOWS32
    FILETYPE        VFT_DLL
    FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    // StringFileInfo – Textfields that get read by the PISInjector
    BLOCK "StringFileInfo"
    BEGIN
        // 040904B0 = German (0409) + Unicode (04B0)
        BLOCK "040904B0"
        BEGIN
            // This Field reads the PISInjector:
            VALUE "ProductName",        MOD_NAME            // → Mod-Name in the Injector
            VALUE "ProductVersion",     MOD_VERSION_STR     // → Version in the Injector
            VALUE "CompanyName",        MOD_AUTHOR          // → Author in the Injector
            VALUE "FileDescription",    MOD_DESCRIPTION     // → Description in the Injector

            // Standart-Windows-Fields (optional):
            VALUE "FileVersion",        MOD_VERSION_STR
            VALUE "InternalName",       "TemplateMod"
            VALUE "OriginalFilename",   "TemplateMod.dll"
        END
    END

    // VarFileInfo – Language/Codepage
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
